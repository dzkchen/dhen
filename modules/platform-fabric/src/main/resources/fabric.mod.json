{
	"schemaVersion": 1,
	"id": "dhen",
	"version": "${version}",
	"name": "dhen",
	"description": "Modular Fabric client host that discovers and runs Dhen addons.",
	"authors": [
		"dzkchen"
	],
	"contact": {
		"sources": "https://github.com/dzkchen/dhen"
	},
	"license": "CC0-1.0",
	"icon": "assets/dhen/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "io.github.dzkchen.dhen.Dhen",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "io.github.dzkchen.dhen.platform.DhenModMenu",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"dhen.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}