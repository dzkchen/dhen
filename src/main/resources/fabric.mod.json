{
	"schemaVersion": 1,
	"id": "dhen",
	"version": "${version}",
	"name": "Dhen",
	"description": "A modular Hypixel SkyBlock client mod for Minecraft.",
	"authors": [
		"dzkchen"
	],
	"contact": {
		"homepage": "https://github.com/dzkchen/dhen",
		"sources": "https://github.com/dzkchen/dhen"
	},
	"license": "MIT",
	"icon": "assets/dhen/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "io.github.dzkchen.dhen.Dhen",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"dhen.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}